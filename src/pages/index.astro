---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import HeroSection from '../components/HeroSection.astro';
import AbstractSection from '../components/AbstractSection.astro';
import OverviewSection from '../components/OverviewSection.astro';
import DataCollectionCard from '../components/DataCollectionCard.astro';
import CitationSection from '../components/CitationSection.astro';

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<Layout title="Act2Cut: Continuous Next-Shot Video Narrative Match on Action-Cut">
  <Navigation page="home" />
  <main class="w-full max-w-5xl mx-auto px-4 sm:px-6 pt-8 pb-16 md:pb-24 flex flex-col gap-16 relative z-10">
    <HeroSection />
    <AbstractSection />
    <OverviewSection />

    <!-- Data Collection & Processing -->
    <DataCollectionCard />

    <!-- Performance Comparison teaser (mini table) -->
    <div data-reveal>
      <div class="text-center mb-6 sm:mb-8">
        <span class="text-[10px] font-bold tracking-[0.32em] uppercase text-white/40 block mb-2">Quantitative Snapshot</span>
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">Performance Comparison</h2>
      </div>

      <!-- Glass card with native HTML table -->
      <div class="relative rounded-2xl sm:rounded-3xl border border-white/[0.08] bg-white/[0.04] backdrop-blur-xl shadow-2xl overflow-hidden">
        <!-- Top sheen -->
        <div
          class="absolute inset-x-0 top-0 h-px pointer-events-none"
          style="background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);"
        ></div>

        <!-- Card header: title + dataset pill -->
        <div class="flex items-center justify-between gap-3 flex-wrap px-5 sm:px-7 pt-5 sm:pt-6 pb-4 border-b border-white/[0.06]">
          <h3 class="text-[13px] sm:text-sm font-semibold text-white/90 tracking-wide">
            ActCutBench Quantitative Results
          </h3>
          <span class="px-2.5 py-1 rounded-md text-[8.5px] sm:text-[9px] font-bold tracking-[0.22em] uppercase text-white/55 bg-white/[0.04] border border-white/[0.08]">
            Dataset · ActCutVid-200K
          </span>
        </div>

        <!-- Table -->
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse text-[12px] sm:text-[13px]">
            <thead>
              <tr class="text-white/45 border-b border-white/[0.06]">
                <th class="px-5 sm:px-7 py-3 font-medium tracking-wide">Method</th>
                <th class="px-3 sm:px-5 py-3 font-medium tracking-wide whitespace-nowrap">FVD <span class="text-white/30">(↓)</span></th>
                <th class="px-3 sm:px-5 py-3 font-medium tracking-wide whitespace-nowrap">CLIP Score <span class="text-white/30">(↑)</span></th>
                <th class="px-3 sm:px-5 py-3 font-medium tracking-wide whitespace-nowrap">Action Continuity <span class="text-white/30">(↑)</span></th>
                <th class="px-3 sm:px-5 py-3 font-medium tracking-wide whitespace-nowrap pr-5 sm:pr-7">Visual Coherence <span class="text-white/30">(↑)</span></th>
              </tr>
            </thead>
            <tbody class="font-mono">
              <!-- Ours row (highlighted) -->
              <tr class="border-b border-white/[0.05] bg-gradient-to-r from-[#ff4d4d]/[0.06] via-[#ff4d4d]/[0.02] to-transparent hover:from-[#ff4d4d]/[0.10] transition-colors">
                <td class="px-5 sm:px-7 py-3.5 font-sans">
                  <span class="inline-flex items-center gap-2.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-[#ff4d4d] shadow-[0_0_10px_#ff4d4d]"></span>
                    <span class="font-bold text-white">Act2Cut <span class="text-white/55 font-medium">(Ours)</span></span>
                  </span>
                </td>
                <td class="px-3 sm:px-5 py-3.5 text-white/90">142.3</td>
                <td class="px-3 sm:px-5 py-3.5 text-white/90">0.31</td>
                <td class="px-3 sm:px-5 py-3.5 font-bold text-transparent bg-clip-text bg-gradient-to-r from-[#ff4d4d] to-[#ffb84d]">0.88</td>
                <td class="px-3 sm:px-5 py-3.5 pr-5 sm:pr-7 text-white/90">0.85</td>
              </tr>

              <!-- Baseline rows -->
              <tr class="border-b border-white/[0.05] hover:bg-white/[0.025] transition-colors">
                <td class="px-5 sm:px-7 py-3.5 font-sans text-white/75">HoloCine-14B</td>
                <td class="px-3 sm:px-5 py-3.5 text-white/55">156.8</td>
                <td class="px-3 sm:px-5 py-3.5 text-white/55">0.29</td>
                <td class="px-3 sm:px-5 py-3.5 text-white/55">0.76</td>
                <td class="px-3 sm:px-5 py-3.5 pr-5 sm:pr-7 text-white/55">0.84</td>
              </tr>

              <tr class="border-b border-white/[0.05] hover:bg-white/[0.025] transition-colors">
                <td class="px-5 sm:px-7 py-3.5 font-sans text-white/75">MSM-14B</td>
                <td class="px-3 sm:px-5 py-3.5 text-white/55">151.2</td>
                <td class="px-3 sm:px-5 py-3.5 text-white/55">0.28</td>
                <td class="px-3 sm:px-5 py-3.5 text-white/55">0.72</td>
                <td class="px-3 sm:px-5 py-3.5 pr-5 sm:pr-7 text-white/55">0.81</td>
              </tr>

              <tr class="hover:bg-white/[0.025] transition-colors">
                <td class="px-5 sm:px-7 py-3.5 font-sans text-white/75">MSM-1.3B</td>
                <td class="px-3 sm:px-5 py-3.5 text-white/55">168.1</td>
                <td class="px-3 sm:px-5 py-3.5 text-white/55">0.27</td>
                <td class="px-3 sm:px-5 py-3.5 text-white/55">0.65</td>
                <td class="px-3 sm:px-5 py-3.5 pr-5 sm:pr-7 text-white/55">0.75</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Card footer / link -->
        <div class="px-5 sm:px-7 py-3.5 border-t border-white/[0.06] flex items-center justify-between gap-3">
          <p class="text-[11px] text-white/35 leading-snug">
            Numbers are placeholder values for layout demonstration.
          </p>
          <a href={`${base}/benchmark`} class="shrink-0 inline-flex items-center gap-1.5 text-[10px] font-bold tracking-[0.22em] uppercase text-transparent bg-clip-text bg-gradient-to-r from-[#ff4d4d] to-[#ffb84d] hover:opacity-80 transition-opacity">
            Full benchmarks
            <svg class="w-3 h-3 text-[#ffb84d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>

    <CitationSection />
  </main>
</Layout>
