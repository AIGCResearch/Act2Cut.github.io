---

<button id="theme-toggle" class="text-xs uppercase tracking-widest opacity-50 hover:opacity-100 transition-opacity flex gap-2 items-center">
  <span class="light-label hidden">Day</span>
  <span class="dark-label hidden">Night</span>
</button>

<script>
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");
    
    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
    updateLabels();
  }

  const updateLabels = () => {
    const isDark = document.documentElement.classList.contains("dark");
    const lightLabel = document.querySelector('.light-label');
    const darkLabel = document.querySelector('.dark-label');
    
    if (isDark) {
      lightLabel?.classList.remove('hidden');
      darkLabel?.classList.add('hidden');
    } else {
      lightLabel?.classList.add('hidden');
      darkLabel?.classList.remove('hidden');
    }
  };

  document.getElementById("theme-toggle")?.addEventListener("click", handleToggleClick);
  
  // Set initial state
  updateLabels();
</script>
