---
const authors = [
  { name: 'Cailin Zhuang', affil: '1,2,3*†' },
  { name: 'Yaoqi Hu',      affil: '2,4*'   },
  { name: 'Zheng Dong',    affil: '2,4'    },
  { name: 'Shiwen Zhang',  affil: '1'      },
  { name: 'Haibin Huang',  affil: '1‡'     },
  { name: 'Chi Zhang',     affil: '1‡'     },
  { name: 'Xuelong Li',    affil: '1‡'     },
];

const authorRows = [authors.slice(0, 3), authors.slice(3)];

const affiliations = [
  { id: '1', name: 'Institute of Artificial Intelligence, China Telecom (TeleAI)' },
  { id: '2', name: 'AIGC Research' },
  { id: '3', name: 'ShanghaiTech University' },
  { id: '4', name: 'Chongqing University of Technology' },
];

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<!-- HEADER / TITLE -->
<header class="text-center space-y-8 sm:space-y-10 mt-8 sm:mt-12 md:mt-16 mb-8 sm:mb-12 px-2 sm:px-4">
  <div data-reveal>
    <h1 class="text-[2.05rem] sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.12] max-w-5xl mx-auto">
      <span class="flex items-center justify-center gap-3 sm:gap-4 md:gap-5 mb-3 sm:mb-4">
        <span class="clapperboard text-[2.1rem] sm:text-5xl md:text-6xl lg:text-7xl leading-none drop-shadow-[0_4px_14px_rgba(255,77,77,0.25)] select-none" aria-hidden="true">🎬</span>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#ff4d4d] to-[#ffb84d] leading-none">Act2Cut</span>
      </span>
      <span class="block mb-1">Continuous <span class="font-normal italic text-white/90">Next-Shot</span> Video</span>
      <span class="block whitespace-nowrap text-[1.12rem] sm:text-[2.35rem] md:text-[2.875rem] lg:text-[4.25rem]">Narrative Match on <span class="text-transparent bg-clip-text bg-gradient-to-b from-white to-white/30">Action-Cut</span></span>
    </h1>
  </div>

  <div class="space-y-5 sm:space-y-6" data-reveal style="transition-delay:100ms">
    <div class="space-y-2 text-[14px] sm:text-[16px] md:text-[17px]">
      {authorRows.map(row => (
        <div class="flex flex-wrap justify-center gap-x-5 gap-y-2">
          {row.map(author => (
            <span class="font-medium text-white/90">
              {author.name}<sup class="text-white/70 ml-0.5">{author.affil}</sup>
            </span>
          ))}
        </div>
      ))}
    </div>
    <div class="flex flex-wrap justify-center gap-x-6 gap-y-1.5 text-[12px] sm:text-[14px] md:text-[15px] text-white/60">
      {affiliations.map(affil => (
        <span><sup class="mr-0.5">{affil.id}</sup>{affil.name}</span>
      ))}
    </div>
    <div class="text-[11.5px] sm:text-[13px] text-white/40 mt-3 sm:mt-4 font-light flex flex-wrap justify-center gap-x-5 gap-y-1">
      <span>* Equal contribution.</span>
      <span>† Work done during internship at TeleAI.</span>
      <span>‡ Corresponding author.</span>
    </div>
  </div>

  <!-- ACTION BUTTONS -->
  <div class="space-y-7 sm:space-y-9 pt-5 sm:pt-8" data-reveal style="transition-delay:200ms">
    <div class="flex flex-wrap justify-center gap-2.5 sm:gap-4 md:gap-6">
      <a href="#" class="px-4 sm:px-7 md:px-8 py-2.5 sm:py-3.5 rounded-full bg-white/5 hover:bg-white/10 border border-white/20 transition-all duration-300 flex items-center gap-2 sm:gap-2.5 text-[13px] sm:text-sm font-medium backdrop-blur-md group">
        <svg class="w-4 h-4 opacity-70 group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
        Paper
      </a>
      <a href="#" class="px-4 sm:px-7 md:px-8 py-2.5 sm:py-3.5 rounded-full bg-white/5 hover:bg-white/10 border border-white/20 transition-all duration-300 flex items-center gap-2 sm:gap-2.5 text-[13px] sm:text-sm font-medium backdrop-blur-md group">
        <svg class="w-4 h-4 opacity-70 group-hover:rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
        Code
      </a>
      <a href="#" class="px-4 sm:px-7 md:px-8 py-2.5 sm:py-3.5 rounded-full bg-white/5 hover:bg-white/10 border border-white/20 transition-all duration-300 flex items-center gap-2 sm:gap-2.5 text-[13px] sm:text-sm font-medium backdrop-blur-md group">
        <svg class="w-4 h-4 opacity-70 group-hover:translate-x-1 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        Video
      </a>
    </div>

    <div class="hidden sm:block mx-auto w-full max-w-[720px] px-10">
      <img
        src={`${base}/images/institution-logos.png`}
        class="institution-logos mx-auto w-full object-contain opacity-75"
        alt="Institute of Artificial Intelligence, China Telecom and AIGC Research"
        loading="eager"
      />
    </div>
  </div>
</header>

<!-- HERO VIDEO with letterbox + timecode -->
<!-- outer section: rounded + overflow-hidden only (no backdrop-blur) to avoid WebKit clip bug -->
<section class="rounded-[1.5rem] sm:rounded-[2rem] overflow-hidden border border-white/20 shadow-2xl relative group aspect-[16/10] sm:aspect-[21/9] flex items-center justify-center" data-reveal style="transition-delay:300ms">
  <!-- Glass backdrop on its own layer — separate from overflow-hidden prevents WebKit border-radius break -->
  <div class="absolute inset-0 bg-black/40 backdrop-blur-xl pointer-events-none"></div>

  <!-- Image -->
  <div class="absolute inset-0 pointer-events-none">
    <img src="https://images.unsplash.com/photo-1578589318433-39b5de440c3f?q=80&w=2939&auto=format&fit=crop" class="w-full h-full object-cover opacity-70 mix-blend-luminosity transform group-hover:scale-105 transition-transform duration-[10s]" alt="Demo Video Placeholder">
  </div>

  <!-- Light leak top-left -->
  <div class="absolute -top-10 -left-10 w-64 h-64 rounded-full pointer-events-none z-10"
    style="background: radial-gradient(circle, rgba(255,77,77,0.15) 0%, transparent 70%); mix-blend-mode: screen;"></div>

  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent z-10 pointer-events-none"></div>

  <!-- Letterbox bars -->
  <div class="absolute top-0 left-0 right-0 h-5 sm:h-8 bg-black z-20 pointer-events-none shadow-[0_4px_12px_rgba(0,0,0,0.6)]"></div>
  <div class="absolute bottom-0 left-0 right-0 h-5 sm:h-8 bg-black z-20 pointer-events-none shadow-[0_-4px_12px_rgba(0,0,0,0.6)]"></div>

  <!-- Play button -->
  <div class="absolute inset-0 flex items-center justify-center z-20">
    <button class="w-16 h-16 sm:w-20 sm:h-20 md:w-24 md:h-24 rounded-full bg-[#ff4d4d]/90 hover:bg-[#ff4d4d] text-white flex items-center justify-center transition-all duration-300 hover:scale-110 shadow-[0_0_40px_rgba(255,77,77,0.5)] backdrop-blur-md">
      <svg class="w-7 h-7 sm:w-9 sm:h-9 md:w-10 md:h-10 ml-1 sm:ml-2" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
    </button>
  </div>

  <div class="absolute bottom-8 sm:bottom-12 left-4 sm:left-8 right-4 sm:right-auto z-20">
    <div class="flex items-center gap-3 mb-2">
      <span class="px-2.5 sm:px-3 py-0.5 sm:py-1 rounded-full border border-[#ff4d4d]/50 bg-[#ff4d4d]/20 text-red-200 text-[10px] sm:text-xs font-medium backdrop-blur-md">Match on Action</span>
    </div>
    <h2 class="text-xl sm:text-2xl md:text-3xl font-bold tracking-tight text-white">Continuous Narrative Generation</h2>
    <p class="text-white/70 font-light mt-1 max-w-xl text-[12px] sm:text-sm hidden sm:block">Demonstrating seamless shot transitions ensuring physical logic and action continuity across cinematic cuts.</p>
  </div>

  <!-- Timecode decoration -->
  <div class="hidden sm:block absolute bottom-12 right-8 z-20 font-mono text-[11px] text-white/15 tracking-widest select-none pointer-events-none">
    00:00:24:00
  </div>
</section>
