---
// Glass-card qualitative gallery — Act2Cut results only, no baseline.
// 3 tabs (T2V / I2V / V2V), 2-column grid.
//   T2V: single 16:9 generated multi-shot tile.
//   I2V: reference frame (1:1) + generated multi-shot tile.
//   V2V: reference prev-shot clip (4:3) + generated multi-shot tile.

const t2v_items = [
  { num: 'T01', short: 'Tying hair',    action: 'Action: [Character 1] is tying up her hair. Shot 1: Medium Close-Up, focus on hand. Shot 2: Over-the-Shoulder, focus on face.' },
  { num: 'T02', short: 'Walk toward',   action: 'Action: [Character 1] walks toward [Character 2] across the room. Shot 1: Wide. Shot 2: Mid-Shot, dolly-in.' },
  { num: 'T03', short: 'Dance move',    action: 'Action: [Character 1] performs a dance move with arm and leg coordination. Shot 1: Wide. Shot 2: Low-Angle Mid-Shot.' },
  { num: 'T04', short: 'Sits, opens',   action: 'Action: [Character 1] sits down and opens a book on the table. Shot 1: Mid-Shot. Shot 2: Cut-In on hands.' },
  { num: 'T05', short: 'Crouches',      action: 'Action: [Character 1] crouches down to pick up an object from the floor. Shot 1: Mid-Shot. Shot 2: ECU on object.' },
  { num: 'T06', short: 'To window',     action: 'Action: [Character 1] turns and looks out of the window thoughtfully. Shot 1: Mid-Shot. Shot 2: Over-the-Shoulder.' },
];

const i2v_items = [
  { num: 'I01', short: 'Tying hair',    action: 'Given first frame — [Character 1] tying hair. Shot 1: ECU. Shot 2: MCU continuation.' },
  { num: 'I02', short: 'Stands → MCU',  action: 'Given first frame — [Character 1] stands up. Shot 1: Mid-Shot. Shot 2: MCU on face.' },
  { num: 'I03', short: 'Handshake',     action: 'Given first frame — handshake. Shot 1: Mid Two-Shot. Shot 2: Cut-In on hands.' },
  { num: 'I04', short: 'Writing desk',  action: 'Given first frame — [Character 1] writing at desk. Shot 1: Wide. Shot 2: MCU.' },
  { num: 'I05', short: 'Opens door',    action: 'Given first frame — [Character 1] opens door. Shot 1: Mid-Shot. Shot 2: Reverse over-shoulder.' },
  { num: 'I06', short: 'Pours drink',   action: 'Given first frame — [Character 1] pours drink. Shot 1: MCU. Shot 2: Reaction OTS.' },
];

const v2v_items = [
  { num: 'V01', short: 'Stands up',      action: 'Given prev-shot clip — [Character 1] stands up. Predict: Match-on-Action cut to next shot.' },
  { num: 'V02', short: 'Crouches',       action: 'Given prev-shot clip — [Character 1] crouches down. Predict: Shot-Reverse-Shot continuation.' },
  { num: 'V03', short: 'Table cut-in',   action: 'Given prev-shot clip — [Character 1] approaches table. Predict: Cut-In to hands on object.' },
  { num: 'V04', short: 'Fight seq.',     action: 'Given prev-shot clip — fight sequence. Predict: multi-step continuation with strike.' },
  { num: 'V05', short: 'Reaction shot',  action: 'Given prev-shot clip — two-character scene. Predict: reaction shot with correct framing.' },
  { num: 'V06', short: 'Anime OOD',      action: 'Given prev-shot clip — OOD anime style; [Character 1] dodging. Zero-shot generalization.' },
];

const tabs = [
  { id: 'qg-t2v', label: 'T2V', sub: 'Text → Video',  mode: 't2v', items: t2v_items },
  { id: 'qg-i2v', label: 'I2V', sub: 'Image → Video', mode: 'i2v', items: i2v_items },
  { id: 'qg-v2v', label: 'V2V', sub: 'Video → Video', mode: 'v2v', items: v2v_items },
];

interface Props {
  instanceId?: string;
  showHeader?: boolean;
}
const { instanceId = 'qg-default', showHeader = true } = Astro.props;
---

<div class="qualitative-gallery space-y-6 md:space-y-8" data-gallery-id={instanceId}>

  {showHeader && (
    <div class="text-center" data-reveal>
      <span class="text-[10px] font-bold tracking-[0.32em] uppercase text-white/40 block mb-3">Qualitative Results</span>
      <h3 class="text-2xl md:text-3xl font-semibold tracking-tight">Generated Sequences</h3>
      <p class="text-white/45 text-sm mt-2 max-w-md mx-auto">Native multi-shot generation across three input modalities.</p>
    </div>
  )}

  <!-- Pill tab bar -->
  <div class="flex justify-center" data-reveal style="transition-delay:60ms">
    <div class="inline-flex items-center gap-1 p-1 rounded-full border border-white/[0.08] bg-white/[0.04] backdrop-blur-xl shadow-inner">
      {tabs.map((tab, i) => (
        <button
          class={`qg-tab-btn relative px-4 sm:px-5 py-1.5 rounded-full text-[11px] font-bold tracking-[0.18em] uppercase transition-all duration-300 ${
            i === 0
              ? 'bg-white text-black shadow-[0_2px_12px_rgba(255,255,255,0.18)]'
              : 'text-white/55 hover:text-white/85'
          }`}
          data-tab={tab.id}
        >
          {tab.label}
        </button>
      ))}
    </div>
  </div>

  <!-- Panels -->
  {tabs.map((tab, ti) => (
    <div
      id={tab.id}
      class:list={['qg-tab-panel', ti !== 0 && 'hidden']}
      data-mode={tab.mode}
    >
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-5">
        {tab.items.map((item, idx) => (
          <article
            class="qg-card group relative rounded-2xl overflow-hidden border border-white/[0.08] bg-white/[0.04] backdrop-blur-xl shadow-2xl transition-all duration-500 hover:border-white/[0.18] hover:bg-white/[0.06] hover:-translate-y-0.5 hover:shadow-[0_24px_60px_rgba(0,0,0,0.5)]"
            data-reveal
            style={`transition-delay:${Math.min(idx * 50, 300)}ms`}
          >
            <!-- Glass sheen highlight -->
            <div
              class="absolute inset-0 pointer-events-none opacity-60 mix-blend-overlay"
              style="background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 35%, transparent 70%, rgba(255,255,255,0.04) 100%);"
            ></div>

            <!-- ID chip (always shown, top-right) -->
            <div class="absolute top-3 right-3 z-20">
              <span class="px-1.5 py-0.5 rounded font-mono text-[8px] font-bold tracking-[0.12em] text-white/45 bg-black/35 border border-white/10 backdrop-blur-sm">
                {item.num}
              </span>
            </div>

            {tab.mode === 't2v' && (
              <!-- T2V: single generated tile -->
              <div class="relative aspect-video bg-black/40 overflow-hidden">
                <div class="absolute top-3 left-3 z-10">
                  <span class="px-2 py-0.5 rounded-md text-[8px] font-bold tracking-[0.18em] uppercase bg-[#ff4d4d]/85 text-white shadow-lg shadow-[#ff4d4d]/20 backdrop-blur-sm">
                    Generated
                  </span>
                </div>
                <div class="absolute inset-0 flex items-center justify-center">
                  <span class="font-mono text-[10px] tracking-[0.28em] uppercase text-white/15 group-hover:text-white/30 transition-colors duration-500">
                    Multi-Shot Sequence
                  </span>
                </div>
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <div class="w-12 h-12 rounded-full bg-[#ff4d4d]/85 flex items-center justify-center shadow-[0_0_30px_rgba(255,77,77,0.45)]">
                    <svg class="w-5 h-5 ml-0.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                </div>
              </div>
            )}

            {tab.mode === 'i2v' && (
              <!-- I2V: input frame stacked above generated -->
              <div class="relative">
                <!-- Input frame -->
                <div class="relative aspect-video bg-black/45 overflow-hidden">
                  <div class="absolute top-3 left-3 z-10">
                    <span class="px-2 py-0.5 rounded-md text-[8px] font-bold tracking-[0.18em] uppercase bg-black/55 text-white/85 border border-white/15 backdrop-blur-sm">
                      Input Frame
                    </span>
                  </div>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <svg class="w-10 h-10 text-white/15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.4">
                      <rect x="3" y="3" width="18" height="18" rx="2"/>
                      <circle cx="9" cy="9" r="2"/>
                      <path d="M21 15l-5-5-9 9"/>
                    </svg>
                  </div>
                </div>

                <!-- Down-arrow connector -->
                <div class="absolute left-1/2 -translate-x-1/2 top-full -mt-3 z-20 w-6 h-6 rounded-full bg-black border border-white/15 flex items-center justify-center shadow-lg">
                  <svg class="w-3 h-3 text-[#ffb84d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                </div>

                <!-- Generated multi-shot -->
                <div class="relative aspect-video bg-black/40 overflow-hidden border-t border-white/[0.08]">
                  <div class="absolute top-3 left-3 z-10">
                    <span class="px-2 py-0.5 rounded-md text-[8px] font-bold tracking-[0.18em] uppercase bg-[#ff4d4d]/85 text-white shadow-lg shadow-[#ff4d4d]/20 backdrop-blur-sm">
                      Generated
                    </span>
                  </div>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <span class="font-mono text-[10px] tracking-[0.28em] uppercase text-white/15 group-hover:text-white/30 transition-colors duration-500">
                      Multi-Shot Sequence
                    </span>
                  </div>
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <div class="w-12 h-12 rounded-full bg-[#ff4d4d]/85 flex items-center justify-center shadow-[0_0_30px_rgba(255,77,77,0.45)]">
                      <svg class="w-5 h-5 ml-0.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                    </div>
                  </div>
                </div>
              </div>
            )}

            {tab.mode === 'v2v' && (
              <!-- V2V: prev shot stacked above generated -->
              <div class="relative">
                <!-- Prev shot clip -->
                <div class="relative aspect-video bg-black/45 overflow-hidden">
                  <div class="absolute top-3 left-3 z-10">
                    <span class="px-2 py-0.5 rounded-md text-[8px] font-bold tracking-[0.18em] uppercase bg-black/55 text-white/85 border border-white/15 backdrop-blur-sm">
                      Prev Shot
                    </span>
                  </div>
                  <!-- Subtle film letterbox -->
                  <div class="absolute top-0 inset-x-0 h-2 bg-black/70 pointer-events-none"></div>
                  <div class="absolute bottom-0 inset-x-0 h-2 bg-black/70 pointer-events-none"></div>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <svg class="w-10 h-10 text-white/15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.4">
                      <rect x="2.5" y="6" width="15" height="12" rx="1.5"/>
                      <path d="M17.5 10l4-2v8l-4-2z"/>
                    </svg>
                  </div>
                </div>

                <!-- Down-arrow connector -->
                <div class="absolute left-1/2 -translate-x-1/2 top-full -mt-3 z-20 w-6 h-6 rounded-full bg-black border border-white/15 flex items-center justify-center shadow-lg">
                  <svg class="w-3 h-3 text-[#ffb84d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
                </div>

                <!-- Generated next-shot continuation -->
                <div class="relative aspect-video bg-black/40 overflow-hidden border-t border-white/[0.08]">
                  <div class="absolute top-3 left-3 z-10">
                    <span class="px-2 py-0.5 rounded-md text-[8px] font-bold tracking-[0.18em] uppercase bg-[#ff4d4d]/85 text-white shadow-lg shadow-[#ff4d4d]/20 backdrop-blur-sm">
                      Generated
                    </span>
                  </div>
                  <div class="absolute inset-0 flex items-center justify-center">
                    <span class="font-mono text-[10px] tracking-[0.28em] uppercase text-white/15 group-hover:text-white/30 transition-colors duration-500">
                      Next-Shot Continuation
                    </span>
                  </div>
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <div class="w-12 h-12 rounded-full bg-[#ff4d4d]/85 flex items-center justify-center shadow-[0_0_30px_rgba(255,77,77,0.45)]">
                      <svg class="w-5 h-5 ml-0.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                    </div>
                  </div>
                </div>
              </div>
            )}

            <!-- Prompt body -->
            <div class="relative p-4 md:p-5 border-t border-white/[0.06]">
              <div class="text-[10px] font-bold tracking-[0.18em] uppercase text-transparent bg-clip-text bg-gradient-to-r from-[#ff4d4d] to-[#ffb84d] mb-2">
                Prompt · {item.short}
              </div>
              <p class="text-[11.5px] leading-relaxed text-white/65 font-light">
                {item.action}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  ))}
</div>

<script>
  // Tab switching for all instances of qualitative-gallery on the page
  document.querySelectorAll('.qualitative-gallery').forEach((gallery) => {
    const btns   = gallery.querySelectorAll<HTMLButtonElement>('.qg-tab-btn');
    const panels = gallery.querySelectorAll<HTMLElement>('.qg-tab-panel');

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.dataset.tab!;

        // Update buttons
        btns.forEach(b => {
          b.classList.remove('bg-white','text-black','shadow-[0_2px_12px_rgba(255,255,255,0.18)]');
          b.classList.add('text-white/55','hover:text-white/85');
        });
        btn.classList.remove('text-white/55','hover:text-white/85');
        btn.classList.add('bg-white','text-black','shadow-[0_2px_12px_rgba(255,255,255,0.18)]');

        // Crossfade panels
        panels.forEach(p => {
          if (p.id === targetId) {
            p.classList.remove('hidden');
            p.style.opacity = '0';
            p.style.transform = 'translateY(8px)';
            requestAnimationFrame(() => requestAnimationFrame(() => {
              p.style.transition = 'opacity 380ms cubic-bezier(0.22,1,0.36,1), transform 380ms cubic-bezier(0.22,1,0.36,1)';
              p.style.opacity = '1';
              p.style.transform = 'translateY(0)';
            }));
          } else {
            p.classList.add('hidden');
            p.style.transition = '';
            p.style.opacity = '';
            p.style.transform = '';
          }
        });
      });
    });
  });
</script>
