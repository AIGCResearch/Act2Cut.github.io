---
const navItems = [
  { label: 'Abstract',  href: '#abstract',  num: '01' },
  { label: 'Overview',  href: '#overview',  num: '02' },
  { label: 'Dataset',   href: '#dataset',   num: '03' },
  { label: 'Benchmark', href: '#benchmark', num: '04' },
  { label: 'Citation',  href: '#citation',  num: '05' },
];
---

<!-- Left side dot nav (xl+) -->
<nav class="hidden xl:flex fixed left-6 top-1/2 -translate-y-1/2 z-50" aria-label="Page sections">
  <div class="flex flex-col items-start">

    <!-- Nav links with vertical guide line -->
    <div class="relative flex flex-col items-start">
      <!-- Vertical line through dots -->
      <div class="absolute top-0 bottom-0 left-[3px] w-px bg-white/[0.08]"></div>

      {navItems.map(item => (
        <a
          href={item.href}
          data-nav-link
          class="relative flex items-center group cursor-pointer py-3 pr-2"
        >
          <span class="nav-dot w-2 h-2 rounded-full border border-white/25 shrink-0 z-10 relative transition-all duration-300"></span>
          <!-- Floating label pill -->
          <span class="nav-lbl absolute left-5 whitespace-nowrap
                       text-[8px] font-bold tracking-[0.24em] uppercase text-white/75
                       bg-black/75 backdrop-blur-md border border-white/[0.1]
                       px-3 py-1.5 rounded-full shadow-lg
                       opacity-0 -translate-x-1 pointer-events-none
                       group-hover:opacity-100 group-hover:translate-x-0
                       transition-all duration-200 ease-out">
            {item.label}
          </span>
        </a>
      ))}
    </div>

    <!-- Separator -->
    <div class="w-3 h-px bg-white/[0.08] ml-0 my-2"></div>

    <!-- Theme toggle -->
    <button
      id="theme-toggle"
      aria-label="Toggle light/dark mode"
      class="relative flex items-center group cursor-pointer py-2 pr-2"
    >
      <span class="w-5 h-5 rounded-full border border-white/20 flex items-center justify-center
                   transition-all duration-300 group-hover:border-white/50 group-hover:bg-white/[0.05]">
        <!-- Moon (dark mode) -->
        <svg class="theme-icon-dark w-2.5 h-2.5 text-white/40 group-hover:text-white/70 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
        <!-- Sun (light mode) -->
        <svg class="theme-icon-light w-2.5 h-2.5 text-white/40 group-hover:text-white/70 transition-colors hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
      </span>
      <!-- Floating label -->
      <span class="theme-toggle-lbl absolute left-6 whitespace-nowrap
                   text-[8px] font-bold tracking-[0.24em] uppercase text-white/75
                   bg-black/75 backdrop-blur-md border border-white/[0.1]
                   px-3 py-1.5 rounded-full shadow-lg
                   opacity-0 -translate-x-1 pointer-events-none
                   group-hover:opacity-100 group-hover:translate-x-0
                   transition-all duration-200 ease-out">
        Light
      </span>
    </button>

  </div>
</nav>

<!-- Floating toggle for non-xl screens -->
<button
  id="theme-toggle-mobile"
  aria-label="Toggle light/dark mode"
  class="xl:hidden fixed bottom-6 right-6 z-50 w-10 h-10 rounded-full border border-white/20 bg-black/40 backdrop-blur-md flex items-center justify-center text-white/50 hover:text-white/80 hover:border-white/40 transition-all duration-300"
>
  <svg class="theme-icon-dark w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
  </svg>
  <svg class="theme-icon-light w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
  </svg>
</button>

<script>
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]');
  const sections  = document.querySelectorAll<HTMLElement>('section[id]');

  const spy = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const id = entry.target.id;
      navLinks.forEach(link => {
        const active = link.getAttribute('href') === `#${id}`;
        const dot = link.querySelector('.nav-dot');
        const lbl = link.querySelector('.nav-lbl');
        if (dot) {
          dot.classList.toggle('nav-dot-active', active);
          dot.classList.toggle('border-white/25', !active);
          dot.classList.toggle('border-transparent', active);
        }
        if (lbl) {
          lbl.classList.toggle('text-white/90', active);
          lbl.classList.toggle('text-white/75', !active);
        }
      });
    });
  }, { rootMargin: '-20% 0px -70% 0px', threshold: 0 });

  sections.forEach(s => spy.observe(s));

  // ── Theme toggle ──────────────────────────────────────────
  function isDark() {
    return document.documentElement.classList.contains('dark');
  }

  function syncUI() {
    const dark = isDark();
    document.querySelectorAll<HTMLElement>('.theme-icon-dark').forEach(el => el.classList.toggle('hidden', !dark));
    document.querySelectorAll<HTMLElement>('.theme-icon-light').forEach(el => el.classList.toggle('hidden', dark));
    const lbl = document.querySelector<HTMLElement>('.theme-toggle-lbl');
    if (lbl) lbl.textContent = dark ? 'Light' : 'Dark';
  }

  function toggleTheme() {
    const html = document.documentElement;
    if (isDark()) {
      html.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      html.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
    syncUI();
  }

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
  document.getElementById('theme-toggle-mobile')?.addEventListener('click', toggleTheme);

  syncUI();
</script>
