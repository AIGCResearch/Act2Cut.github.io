---
const navItems = [
  { label: 'Abstract',  href: '#abstract',  num: '01' },
  { label: 'Overview',  href: '#overview',  num: '02' },
  { label: 'Dataset',   href: '#dataset',   num: '03' },
  { label: 'Benchmark', href: '#benchmark', num: '04' },
  { label: 'Citation',  href: '#citation',  num: '05' },
];
---

<nav class="hidden xl:flex fixed right-6 top-1/2 -translate-y-1/2 z-50">
  <div class="relative flex flex-col">
    <!-- Vertical connecting line -->
    <div style="position:absolute;left:calc(100% - 4px);top:0;bottom:0;width:1px;background:rgba(255,255,255,0.08);"></div>

    {navItems.map(item => (
      <a
        href={item.href}
        data-nav-link
        class="py-3.5 flex items-center group cursor-pointer"
      >
        <!-- Section label -->
        <span class="nav-lbl text-[9px] tracking-[0.2em] uppercase font-semibold text-white/25 group-hover:text-white/70 transition-colors">
          {item.label}
        </span>
        <!-- Chapter number -->
        <span class="nav-num text-[11px] font-mono text-white/20 ml-3 group-hover:text-white/50 transition-colors">
          {item.num}
        </span>
        <!-- Dot -->
        <span class="nav-dot w-2 h-2 rounded-full border border-white/20 ml-3 shrink-0 transition-all duration-300"></span>
      </a>
    ))}
  </div>
</nav>

<script>
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('[data-nav-link]');
  const sections = document.querySelectorAll<HTMLElement>('section[id]');

  const spy = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const id = entry.target.id;
      navLinks.forEach(link => {
        const active = link.getAttribute('href') === `#${id}`;
        link.classList.toggle('nav-link-active', active);
        const dot = link.querySelector('.nav-dot');
        const num = link.querySelector('.nav-num');
        const lbl = link.querySelector('.nav-lbl');
        if (dot) {
          dot.classList.toggle('nav-dot-active', active);
          dot.classList.toggle('border-white/20', !active);
          dot.classList.toggle('border-transparent', active);
        }
        if (num) {
          num.classList.toggle('nav-num-active', active);
          num.classList.toggle('text-white/20', !active);
        }
        if (lbl) {
          lbl.classList.toggle('text-white/90', active);
          lbl.classList.toggle('text-white/25', !active);
        }
      });
    });
  }, { rootMargin: '-20% 0px -70% 0px', threshold: 0 });

  sections.forEach(s => spy.observe(s));
</script>
