---
// Data Collection & Processing — featured on the home page.
// Right pane shows an actual visual demo of hierarchical prompting,
// not a screenshot.

const base = import.meta.env.BASE_URL.replace(/\/+$/, '');

const layers = [
  { tag: 'Global',     dot: '#ff4d4d', body: 'Soft, warm sunlight filters through large windows of a quiet apartment.', sub: 'Env · Scene · Style' },
  { tag: 'Local',      dot: '#ff7a3d', body: 'Shot 1: Medium Close-Up, focus on hand.   Shot 2: Over-the-Shoulder, focus on face.', sub: 'Static / Dynamic Cinematography' },
  { tag: 'Action',     dot: '#ffa14d', body: '[Character 1] is tying up her hair, then turns slightly toward [Character 2].', sub: 'Subject behaviour · Motion' },
  { tag: 'Transition', dot: '#ffb84d', body: 'Hard Cut · Cut-Out · Shot Reverse Shot.',                                       sub: 'Edit-point relation' },
];
---

<section class="rounded-2xl sm:rounded-3xl p-6 sm:p-8 md:p-10 border border-white/10 bg-black/40 backdrop-blur-xl shadow-2xl" data-reveal>

  <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_1fr] gap-8 md:gap-10 items-stretch">

    <!-- LEFT: copy -->
    <div class="space-y-5 sm:space-y-6 flex flex-col">
      <div>
        <span class="text-[10px] font-bold tracking-[0.32em] uppercase text-white/40 block mb-2">Dataset · ActCutVid-200k</span>
        <h3 class="text-xl sm:text-2xl font-semibold tracking-tight">
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#ff4d4d] to-[#ffb84d]">Data Collection</span>
          <span class="text-white/85">&amp; Processing</span>
        </h3>
      </div>

      <p class="text-[13px] sm:text-sm text-white/75 leading-relaxed font-light">
        Sourced from films, TV series, and AI-generated content (Sora2, Seedance2.0).
        We pair <strong class="text-white">TransNetV2</strong> with our novel
        <strong class="text-white">Similarity Clustering Boundary Optimizer (SCBO)</strong>
        via CLIP/DINO to precisely calibrate shot boundaries.
      </p>

      <ul class="space-y-3 sm:space-y-3.5 text-[13px] sm:text-sm text-white/70 font-light">
        <li class="flex items-start gap-3">
          <span class="mt-0.5 inline-flex w-5 h-5 rounded-md bg-[#ffb84d]/15 border border-[#ffb84d]/30 items-center justify-center shrink-0">
            <svg class="w-3 h-3 text-[#ffb84d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          </span>
          <span><strong class="text-white/90">0–4 Likert Scale:</strong> assessed via Gemini-3-Pro, distinguishing Strong Action-Cut (4) from Weak Action-Cut (1–3).</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-0.5 inline-flex w-5 h-5 rounded-md bg-[#ffb84d]/15 border border-[#ffb84d]/30 items-center justify-center shrink-0">
            <svg class="w-3 h-3 text-[#ffb84d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          </span>
          <span><strong class="text-white/90">Hierarchical Annotations:</strong> decoupled cinematographic shot-language across Global · Local · Action · Transition layers.</span>
        </li>
      </ul>

      <div class="mt-auto pt-2">
        <a href={`${base}/dataset`} class="inline-flex items-center gap-1.5 text-[10px] font-bold tracking-[0.22em] uppercase text-transparent bg-clip-text bg-gradient-to-r from-[#ff4d4d] to-[#ffb84d] hover:opacity-80 transition-opacity">
          Explore the dataset
          <svg class="w-3 h-3 text-[#ffb84d]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <!-- RIGHT: hierarchical prompting visual demo -->
    <div class="relative rounded-2xl border border-white/[0.08] bg-white/[0.025] overflow-hidden p-4 sm:p-5">
      <!-- Glass sheen -->
      <div class="absolute inset-0 pointer-events-none opacity-60 mix-blend-overlay"
           style="background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 35%, transparent 70%, rgba(255,255,255,0.04) 100%);"></div>
      <!-- Light leak -->
      <div class="absolute -top-8 -right-8 w-40 h-40 rounded-full pointer-events-none"
           style="background: radial-gradient(circle, rgba(255,184,77,0.10) 0%, transparent 70%); mix-blend-mode: screen;"></div>

      <div class="relative">
        <div class="flex items-center justify-between mb-3 sm:mb-4">
          <span class="text-[9px] font-bold tracking-[0.28em] uppercase text-white/35">Hierarchical Prompting</span>
          <span class="font-mono text-[8.5px] tracking-[0.18em] text-white/25 uppercase">S1 → S2</span>
        </div>

        <!-- Two-shot strip -->
        <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2 sm:gap-3 mb-4 sm:mb-5">
          <!-- Shot 1 -->
          <div class="relative rounded-lg overflow-hidden border border-white/10 bg-black/45 aspect-[16/10]">
            <div class="absolute top-1.5 left-1.5 px-1.5 py-px rounded font-mono text-[7.5px] tracking-[0.18em] uppercase text-white/55 bg-black/40 border border-white/10">S1 · MCU</div>
            <div class="absolute inset-0 flex items-center justify-center">
              <!-- Stylised shot frame -->
              <svg class="w-8 h-8 text-white/15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <circle cx="12" cy="9" r="3.5"/><path d="M5 20c1.5-3 4-4.5 7-4.5s5.5 1.5 7 4.5"/>
              </svg>
            </div>
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/55 to-transparent"></div>
          </div>

          <!-- Cut indicator -->
          <div class="flex flex-col items-center gap-1">
            <div class="w-px h-4 bg-gradient-to-b from-transparent to-[#ff4d4d]"></div>
            <div class="px-1.5 py-0.5 rounded font-mono text-[7.5px] tracking-[0.22em] uppercase font-bold text-[#ff4d4d] border border-[#ff4d4d]/40 bg-[#ff4d4d]/10 leading-none">Cut</div>
            <div class="w-px h-4 bg-gradient-to-t from-transparent to-[#ff4d4d]"></div>
          </div>

          <!-- Shot 2 -->
          <div class="relative rounded-lg overflow-hidden border border-white/10 bg-black/45 aspect-[16/10]">
            <div class="absolute top-1.5 left-1.5 px-1.5 py-px rounded font-mono text-[7.5px] tracking-[0.18em] uppercase text-white/55 bg-black/40 border border-white/10">S2 · OTS</div>
            <div class="absolute inset-0 flex items-center justify-center">
              <svg class="w-8 h-8 text-white/15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path d="M3 12c2-3 5-5 9-5s7 2 9 5"/><circle cx="14" cy="11" r="3"/>
              </svg>
            </div>
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/55 to-transparent"></div>
          </div>
        </div>

        <!-- Caption layer stack -->
        <ul class="space-y-1.5">
          {layers.map((layer, i) => (
            <li
              class="layer-row group relative rounded-lg border border-white/[0.06] bg-white/[0.02] hover:bg-white/[0.04] hover:border-white/[0.12] transition-all duration-300 px-2.5 py-2 flex items-start gap-2.5"
              style={`transition-delay:${i * 60}ms`}
            >
              <span
                class="mt-1 w-2 h-2 rounded-full shrink-0 shadow-[0_0_10px_currentColor]"
                style={`background:${layer.dot};color:${layer.dot}`}
              ></span>
              <div class="flex-1 min-w-0">
                <div class="flex items-baseline justify-between gap-2">
                  <span class="font-mono text-[9px] tracking-[0.22em] uppercase font-bold text-white/85">{layer.tag}</span>
                  <span class="text-[8.5px] tracking-[0.12em] uppercase text-white/30 truncate">{layer.sub}</span>
                </div>
                <p class="font-mono text-[10.5px] sm:text-[11px] leading-snug text-white/55 mt-0.5 line-clamp-2">{layer.body}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>

  </div>
</section>
