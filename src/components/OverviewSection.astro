---
const methodCards = [
  {
    abbr: 'TBR',
    title: 'Transitional Boundary Residual',
    desc: `Enhances spatial and kinetic consistency at the edit point between adjacent shots. Ensures the terminal frame of shot <em>n</em> and the initial frame of shot <em>n+1</em> maintain rigorous 3D spatial alignment and smooth momentum continuity, preventing visual "popping" at hard cuts.`
  },
  {
    abbr: 'GLoS-RoPE',
    title: 'Global-Local Shot RoPE',
    desc: `Decouples temporal position encoding across shot boundaries. Global tokens carry sequence-level context while local tokens remain precisely positioned within their own shot — enabling cross-shot coherence without RoPE bleed between unrelated frames.`
  },
  {
    abbr: 'SCM',
    title: 'Shot Causal Mask',
    desc: `Applies a unidirectional causal constraint in self-attention so that shot <em>x<sub>i</sub></em> can attend to the history of <em>x<sub>i−1</sub></em>, but not vice versa. Prevents "semantic leakage" where future shot compositions contaminate earlier frames.`
  },
  {
    abbr: 'HCM',
    title: 'Hierarchical Context Mask',
    desc: `Partitions cross-attention into global, relational, and local windows. Global tokens act as universal anchors; per-shot cinematic language remains independently modulated, ensuring precise control over "what happens" vs. "how it is framed" for each shot.`
  },
];

// ── Item data (num + short label + full action description) ──────────────
const t2v_items = [
  { num: 'T01', short: 'Tying hair',    action: 'Character is tying up her hair. Shot 1 → Shot 2 (Match on Action).' },
  { num: 'T02', short: 'Walk toward',   action: 'Character walks toward another character across the room.' },
  { num: 'T03', short: 'Dance move',    action: 'Character performs a dance move with arm and leg coordination.' },
  { num: 'T04', short: 'Sits, opens',   action: 'Character sits down and opens a book on the table.' },
  { num: 'T05', short: 'Crouches',      action: 'Character crouches down to pick up an object from the floor.' },
  { num: 'T06', short: 'To window',     action: 'Character turns and looks out of the window thoughtfully.' },
  { num: 'T07', short: 'Dialogue',      action: 'Two characters face each other; character 1 speaks while character 2 listens.' },
  { num: 'T08', short: 'Runs, turns',   action: 'Character runs through a narrow corridor, turns a corner.' },
  { num: 'T09', short: 'On shelf',      action: 'Character reaches for something on the top shelf, struggles briefly.' },
  { num: 'T10', short: 'Enters room',   action: 'Character enters a room, pauses, and looks around taking in the scene.' },
];

const i2v_items = [
  { num: 'I01', short: 'Tying hair',    action: 'Given first frame — character tying hair, action continues through cut.' },
  { num: 'I02', short: 'Stands → MCU',  action: 'Given first frame — character standing up from chair, Mid-Shot → Close-Up.' },
  { num: 'I03', short: 'Handshake',     action: 'Given first frame — two characters shaking hands; Cut-In on hands.' },
  { num: 'I04', short: 'Writing desk',  action: 'Given first frame — character writing at desk, zoom from Wide to MCU.' },
  { num: 'I05', short: 'Opens door',    action: 'Given first frame — character opening a door and stepping through.' },
  { num: 'I06', short: 'Pours drink',   action: 'Given first frame — character pouring drink, Over-Shoulder reaction shot.' },
  { num: 'I07', short: 'Throws obj',    action: 'Given first frame — character throwing an object, Cut-Out to wide establishing.' },
  { num: 'I08', short: 'Points',        action: 'Given first frame — character pointing; Cut-In to detail of finger.' },
  { num: 'I09', short: 'Climbs stairs', action: 'Given first frame — outdoor scene, character climbing stairs, Low-Angle to Eye-Level.' },
  { num: 'I10', short: 'Reading pan',   action: 'Given first frame — character reading, slow pan to close-up on face expression.' },
];

const v2v_items = [
  { num: 'V01', short: 'Stands up',      action: 'Given prev-shot clip — character standing up; predict Match on Action cut to next shot.' },
  { num: 'V02', short: 'Crouches',       action: 'Given prev-shot clip — character crouching down; Shot-Reverse-Shot prediction.' },
  { num: 'V03', short: 'Table cut-in',   action: 'Given prev-shot clip — character approaching table; Cut-In to hands on object.' },
  { num: 'V04', short: 'Fight seq.',     action: 'Given prev-shot clip — complex fight sequence; multi-step action continuation.' },
  { num: 'V05', short: 'Reaction shot',  action: 'Given prev-shot clip — two-character scene; predict reaction shot with correct framing.' },
  { num: 'V06', short: 'Anime OOD',      action: 'Given prev-shot clip — OOD anime style; character dodging; zero-shot generalization.' },
  { num: 'V07', short: 'Group decouple', action: 'Given prev-shot clip — group shot, character action decoupling across multiple subjects.' },
  { num: 'V08', short: 'CU → wide',      action: 'Given prev-shot clip — extreme close-up, character blinking; predict complementary wide shot.' },
  { num: 'V09', short: 'Dutch → eye',    action: 'Given prev-shot clip — character walking outdoors; Dutch angle to Eye-Level continuity.' },
  { num: 'V10', short: '14B · 5 shots',  action: 'Given prev-shot clip — 14B model scaling test; complex sequence with 5 shots.' },
];

// ── Page chunking (5 per page → 2 pages per tab) ────────────────────────
const PAGE = 5;
function chunk<T>(arr: T[], n: number): T[][] {
  const out: T[][] = [];
  for (let i = 0; i < arr.length; i += n) out.push(arr.slice(i, i + n));
  return out;
}

const allTabs = [
  {
    id: 'otab-t2v',
    label: 'Text → Video',
    pages: chunk(t2v_items, PAGE),
    rows: [
      { label: 'MSM-14B', isAccent: false, isInput: false },
      { label: 'Act2Cut',  isAccent: true,  isInput: false },
    ],
  },
  {
    id: 'otab-i2v',
    label: 'Image → Video',
    pages: chunk(i2v_items, PAGE),
    rows: [
      { label: 'Input Frame', isAccent: false, isInput: true  },
      { label: 'MSM-14B',     isAccent: false, isInput: false },
      { label: 'Act2Cut',     isAccent: true,  isInput: false },
    ],
  },
  {
    id: 'otab-v2v',
    label: 'Video → Video',
    pages: chunk(v2v_items, PAGE),
    rows: [
      { label: 'Prev Shot', isAccent: false, isInput: true  },
      { label: 'MSM-14B',   isAccent: false, isInput: false },
      { label: 'Act2Cut',   isAccent: true,  isInput: false },
    ],
  },
];
---

<section id="overview" class="space-y-12">

  <!-- Section header -->
  <div data-reveal>
    <span class="act-marker">ACT Ⅱ</span>
    <h2 class="text-3xl font-semibold tracking-tight flex items-center gap-3 mt-1">
      <span class="inline-block w-1 h-7 bg-gradient-to-b from-[#ff4d4d] to-[#ffb84d] rounded-sm" style="transform: skewX(-6deg);"></span>
      Method &amp; Results
    </h2>
    <p class="text-white/50 text-sm mt-2">Demo video, architecture overview, and qualitative comparison.</p>
  </div>

  <!-- Demo video placeholder -->
  <div class="rounded-3xl overflow-hidden border border-white/10 bg-black/40 backdrop-blur-xl shadow-2xl relative aspect-video flex items-center justify-center" data-reveal style="transition-delay:100ms">
    <div class="absolute inset-0 flex flex-col items-center justify-center gap-4 text-white/40">
      <div class="w-16 h-16 rounded-full border border-white/20 flex items-center justify-center">
        <svg class="w-6 h-6 ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
      </div>
      <span class="text-[9px] tracking-[0.28em] uppercase font-semibold">Demo Video — Replace with actual video</span>
    </div>
  </div>

  <!-- Architecture diagram placeholder -->
  <div class="rounded-3xl overflow-hidden border border-white/10 bg-black/40 backdrop-blur-xl shadow-lg relative flex items-center justify-center text-white/30 p-8" style="aspect-ratio:16/7; transition-delay:150ms;" data-reveal>
    <div class="text-center">
      <div class="text-[10px] tracking-[0.28em] uppercase font-semibold mb-1">Architecture Diagram</div>
      <div class="text-[11px] text-white/20 italic">Fig. 3 — Replace with actual figure</div>
    </div>
  </div>

  <div class="film-strip-divider"></div>

  <!-- Method cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
    {methodCards.map((card, i) => (
      <div
        class="rounded-3xl p-8 border border-white/10 bg-black/40 backdrop-blur-xl shadow-lg hover:bg-white/5 hover:border-[#ff4d4d]/30 transition-all duration-300 chroma-hover"
        data-reveal
        style={`transition-delay:${i * 100}ms`}
      >
        <span class="text-[10px] font-bold tracking-[0.28em] uppercase text-transparent bg-clip-text bg-gradient-to-r from-[#ff4d4d] to-[#ffb84d] block mb-2">{card.abbr}</span>
        <h3 class="text-xl font-semibold mb-3 text-white">{card.title}</h3>
        <p class="text-sm text-white/70 leading-relaxed font-light" set:html={card.desc}></p>
      </div>
    ))}
  </div>

  <div class="film-strip-divider"></div>

  <!-- Qualitative Results -->
  <div>
    <div data-reveal>
      <span class="text-[10px] font-bold tracking-[0.28em] uppercase text-white/40 block mb-2">Qualitative Results</span>
      <h3 class="text-2xl font-semibold tracking-tight mb-6">Generated Sequences vs. Baseline</h3>
    </div>

    <!-- Tab bar -->
    <div class="flex gap-0 border-b border-white/10 mb-8" data-reveal style="transition-delay:80ms">
      {allTabs.map((tab, i) => (
        <button
          class={`overview-tab-btn px-0 mr-9 py-4 text-[11px] font-bold tracking-[0.18em] uppercase border-b-2 transition-all duration-200 whitespace-nowrap ${i === 0 ? 'text-transparent bg-clip-text bg-gradient-to-r from-[#ff4d4d] to-[#ffb84d] border-[#ff4d4d]' : 'text-white/40 hover:text-white border-transparent'}`}
          data-tab={tab.id}
        >
          {tab.label}
        </button>
      ))}
    </div>

    <!-- Tab panels -->
    {allTabs.map((tab, tabIdx) => (
      <div id={tab.id} class={`overview-tab-panel ${tabIdx !== 0 ? 'hidden' : ''}`}>

        <!-- ── Pagination bar ── -->
        <div
          class="flex items-center justify-between mb-4"
          data-pager={tab.id}
        >
          <!-- Prev -->
          <button
            data-pager-prev
            class="flex items-center gap-1.5 text-[9px] font-bold tracking-[0.2em] uppercase text-white/30 hover:text-white/70 transition-all duration-200 disabled:opacity-20"
            style="opacity:0.25"
          >
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/>
            </svg>
            Prev
          </button>

          <!-- Page dots -->
          <div class="flex items-center gap-2">
            {tab.pages.map((_, pi) => (
              <button
                data-pager-dot={pi}
                class:list={[
                  'pager-dot w-1.5 h-1.5 rounded-full transition-all duration-300 cursor-pointer',
                  pi === 0
                    ? 'w-4 bg-gradient-to-r from-[#ff4d4d] to-[#ffb84d]'
                    : 'bg-white/20 hover:bg-white/40',
                ]}
              ></button>
            ))}
          </div>

          <!-- Next -->
          <button
            data-pager-next
            class="flex items-center gap-1.5 text-[9px] font-bold tracking-[0.2em] uppercase text-white/30 hover:text-white/70 transition-all duration-200"
          >
            Next
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
            </svg>
          </button>
        </div>

        <!-- ── Glass comparison table ── -->
        <div class="rounded-2xl overflow-hidden border border-white/[0.08] bg-white/[0.02] backdrop-blur-xl shadow-xl" data-reveal style="transition-delay:120ms">

          {tab.pages.map((pageItems, pi) => (
            <div class={`page-panel ${pi !== 0 ? 'hidden' : ''}`} data-page={pi}>

              <!-- Column headers -->
              <div
                class="grid border-b border-white/[0.08] bg-white/[0.02]"
                style={`grid-template-columns: 96px repeat(${pageItems.length}, 1fr)`}
              >
                <div class="px-4 py-3 border-r border-white/[0.05] flex items-end">
                  <span class="text-[7px] font-bold tracking-[0.28em] uppercase text-white/25">Model</span>
                </div>
                {pageItems.map((item) => (
                  <div class="px-2 pt-3 pb-2.5 text-center border-r border-white/[0.04] last:border-r-0">
                    <div class="text-[10px] font-bold tracking-[0.14em] text-transparent bg-clip-text bg-gradient-to-r from-[#ff4d4d] to-[#ffb84d] leading-none">
                      {item.num}
                    </div>
                    <div class="text-[7px] text-white/30 mt-1 leading-tight">{item.short}</div>
                  </div>
                ))}
              </div>

              <!-- Model rows -->
              {tab.rows.map((row, rowIdx) => (
                <div
                  class:list={[
                    'grid',
                    rowIdx > 0 && 'border-t border-white/[0.06]',
                    row.isInput  && 'bg-white/[0.025]',
                    row.isAccent && 'bg-gradient-to-r from-[#ff4d4d]/[0.05] to-transparent',
                  ]}
                  style={`grid-template-columns: 96px repeat(${pageItems.length}, 1fr)`}
                >
                  <!-- Row label -->
                  <div class="px-4 py-2.5 flex items-center border-r border-white/[0.05]">
                    {row.isAccent ? (
                      <span class="text-[8px] font-bold tracking-[0.14em] uppercase text-transparent bg-clip-text bg-gradient-to-r from-[#ff4d4d] to-[#ffb84d]">
                        ★ Act2Cut
                      </span>
                    ) : (
                      <span class:list={[
                        'text-[8px] font-semibold tracking-[0.14em] uppercase',
                        row.isInput ? 'text-white/40' : 'text-white/30',
                      ]}>
                        {row.label}
                      </span>
                    )}
                  </div>

                  <!-- Video cells -->
                  {pageItems.map(() => (
                    <div class="p-2 border-r border-white/[0.04] last:border-r-0">
                      <div class:list={[
                        'aspect-video rounded-lg flex items-center justify-center',
                        'transition-all duration-300 cursor-pointer group',
                        row.isAccent
                          ? 'bg-black/50 border border-[#ff4d4d]/15 hover:border-[#ff4d4d]/55 hover:bg-[#ff4d4d]/[0.04] hover:shadow-[0_0_20px_rgba(255,77,77,0.12)]'
                          : row.isInput
                            ? 'bg-black/40 border border-white/[0.12] hover:border-white/30'
                            : 'bg-black/50 border border-white/[0.07] hover:border-white/25',
                      ]}>
                        <svg
                          class:list={[
                            'w-4 h-4 ml-0.5 transition-all duration-300',
                            row.isAccent
                              ? 'text-[#ff4d4d]/20 group-hover:text-[#ff4d4d]/60 group-hover:scale-110'
                              : 'text-white/12 group-hover:text-white/35 group-hover:scale-110',
                          ]}
                          fill="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path d="M8 5v14l11-7z"/>
                        </svg>
                      </div>
                    </div>
                  ))}
                </div>
              ))}

            </div>
          ))}

        </div>

      </div>
    ))}
  </div>

</section>

<script>
  // ── Tab switching ─────────────────────────────────────────────────────
  const tabBtns  = document.querySelectorAll<HTMLButtonElement>('.overview-tab-btn');
  const tabPanels = document.querySelectorAll<HTMLElement>('.overview-tab-panel');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      tabBtns.forEach(b => {
        b.classList.remove('text-transparent','bg-clip-text','bg-gradient-to-r','from-[#ff4d4d]','to-[#ffb84d]','border-[#ff4d4d]');
        b.classList.add('text-white/40','border-transparent');
      });
      btn.classList.remove('text-white/40','border-transparent');
      btn.classList.add('text-transparent','bg-clip-text','bg-gradient-to-r','from-[#ff4d4d]','to-[#ffb84d]','border-[#ff4d4d]');

      tabPanels.forEach(p => p.classList.add('hidden'));
      const target = document.getElementById(btn.dataset.tab!);
      if (target) {
        target.classList.remove('hidden');
        target.style.opacity = '0';
        target.style.transition = '';
        requestAnimationFrame(() => requestAnimationFrame(() => {
          target.style.transition = 'opacity 450ms cubic-bezier(0.22,1,0.36,1)';
          target.style.opacity = '1';
        }));
        // reset pager to page 0
        initPager(btn.dataset.tab!);
      }
    });
  });

  // ── Pager ─────────────────────────────────────────────────────────────
  function initPager(tabId: string) {
    const panel = document.getElementById(tabId);
    if (!panel) return;
    const pagerBar   = panel.querySelector<HTMLElement>(`[data-pager="${tabId}"]`);
    if (!pagerBar) return;

    const pagePanels = panel.querySelectorAll<HTMLElement>('.page-panel');
    const dots       = pagerBar.querySelectorAll<HTMLElement>('[data-pager-dot]');
    const prevBtn    = pagerBar.querySelector<HTMLButtonElement>('[data-pager-prev]');
    const nextBtn    = pagerBar.querySelector<HTMLButtonElement>('[data-pager-next]');

    // Retrieve or default page index stored on the bar element
    let cur = parseInt((pagerBar as any)._curPage ?? '0', 10);

    function goTo(idx: number) {
      if (idx < 0 || idx >= pagePanels.length) return;

      const oldPanel = pagePanels[cur];
      const newPanel = pagePanels[idx];
      cur = idx;
      (pagerBar as any)._curPage = idx;

      // Fade out → swap → fade in
      oldPanel.style.transition = 'opacity 180ms ease';
      oldPanel.style.opacity    = '0';
      setTimeout(() => {
        oldPanel.classList.add('hidden');
        oldPanel.style.opacity    = '';
        oldPanel.style.transition = '';
        newPanel.classList.remove('hidden');
        newPanel.style.opacity    = '0';
        newPanel.style.transition = '';
        requestAnimationFrame(() => requestAnimationFrame(() => {
          newPanel.style.transition = 'opacity 320ms cubic-bezier(0.22,1,0.36,1)';
          newPanel.style.opacity    = '1';
          setTimeout(() => {
            newPanel.style.transition = '';
            newPanel.style.opacity    = '';
          }, 350);
        }));
      }, 190);

      // Update dots
      dots.forEach((dot, i) => {
        if (i === idx) {
          dot.classList.remove('bg-white/20','hover:bg-white/40','w-1.5');
          dot.classList.add('w-4','bg-gradient-to-r','from-[#ff4d4d]','to-[#ffb84d]');
        } else {
          dot.classList.remove('w-4','bg-gradient-to-r','from-[#ff4d4d]','to-[#ffb84d]');
          dot.classList.add('w-1.5','bg-white/20','hover:bg-white/40');
        }
      });

      // Update arrow opacity
      if (prevBtn) prevBtn.style.opacity = idx === 0 ? '0.25' : '1';
      if (nextBtn) nextBtn.style.opacity = idx === pagePanels.length - 1 ? '0.25' : '1';
    }

    // Wire up arrows
    prevBtn?.addEventListener('click', () => goTo(cur - 1));
    nextBtn?.addEventListener('click', () => goTo(cur + 1));

    // Wire up dot buttons
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

    // Reset to page 0 (e.g. after tab switch)
    // Show only page 0, hide others
    pagePanels.forEach((p, i) => i === 0 ? p.classList.remove('hidden') : p.classList.add('hidden'));
    (pagerBar as any)._curPage = 0;
    cur = 0;
    dots.forEach((dot, i) => {
      if (i === 0) {
        dot.classList.remove('bg-white/20','hover:bg-white/40','w-1.5');
        dot.classList.add('w-4','bg-gradient-to-r','from-[#ff4d4d]','to-[#ffb84d]');
      } else {
        dot.classList.remove('w-4','bg-gradient-to-r','from-[#ff4d4d]','to-[#ffb84d]');
        dot.classList.add('w-1.5','bg-white/20','hover:bg-white/40');
      }
    });
    if (prevBtn) prevBtn.style.opacity = '0.25';
    if (nextBtn) nextBtn.style.opacity = pagePanels.length <= 1 ? '0.25' : '1';
  }

  // Init pagers for all tabs on load
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll<HTMLElement>('[data-pager]').forEach(bar => {
      initPager(bar.dataset.pager!);
    });
  });
</script>
